{
  "_comment": "Esquema declarativo del informe SIMCE Panguipulli. Cada sección llama a charts.py/tables.py vía CHART_REGISTRY/TABLE_REGISTRY. df_input matchea las keys que pasa el orquestador (estudiantes, estudiantes_prueba, habilidad, habilidad_prueba). Variante de SIMCE/esquema.json sin secciones de Pregunta/Eje Temático/Puntaje SIMCE — esas dimensiones no existen en los datos Panguipulli.",
  "derived_fields": [
    {
      "_comment": "Sobre df 'estudiantes' (todas las pruebas). 1) clasifica Nivel_Logro por umbrales D1; 2) calcula avance/mejora del estudiante a lo largo del año (slope/delta sobre PorcLogro).",
      "df_input": "estudiantes",
      "configs": [
        {
          "kind": "row_threshold",
          "name": "Nivel_Logro",
          "value_field": "PorcLogro",
          "thresholds": [
            {"max": 0.40, "label": "Insuficiente"},
            {"max": 0.60, "label": "Elemental"},
            {"max": null, "label": "Adecuado"}
          ]
        },
        {
          "kind": "agg",
          "name": "Logro_Promedio_Estudiante",
          "value_field": "PorcLogro",
          "entity_field": ["Rut", "Asignatura"],
          "agg": "mean",
          "min_points": 1
        },
        {
          "kind": "slope",
          "name": "Avance",
          "value_field": "PorcLogro",
          "entity_field": ["Rut", "Asignatura"],
          "time_field": "Mes",
          "time_type": "ordinal",
          "time_ordinal_levels": ["ABRIL", "MAYO", "AGOSTO", "SEPTIEMBRE"],
          "min_points": 2
        },
        {
          "kind": "delta",
          "name": "Mejora_vs_Inicio",
          "value_field": "PorcLogro",
          "entity_field": ["Rut", "Asignatura"],
          "time_field": "Mes",
          "time_type": "ordinal",
          "time_ordinal_levels": ["ABRIL", "MAYO", "AGOSTO", "SEPTIEMBRE"],
          "min_points": 2
        }
      ]
    }
  ],
  "title": "Informe SIMCE Panguipulli",
  "subtitle": "Resumen de la prueba seleccionada",
  "filters_label": "",
  "branding": {
    "left_image": "logo_php.png",
    "right_image": null,
    "center_header": [
      "Informe SIMCE Panguipulli",
      "Asignatura - Curso",
      "Mes Año"
    ],
    "left_footer": "Miguel Godoy Díaz",
    "show_page_number": true
  },
  "secciones_fijas": [
    {
      "tipo": "table",
      "titulo": "Resumen de Logro por Curso",
      "fn": "resumen_estadistico_basico",
      "df_input": "estudiantes_prueba",
      "params": {
        "columna": "PorcLogro",
        "formato": "percent",
        "agrupar_por": "Curso"
      }
    },
    {
      "tipo": "chart",
      "titulo": "Rendimiento Promedio por Curso",
      "fn": "grafico_barras_promedio_por",
      "df_input": "estudiantes_prueba",
      "params": {
        "columna_valor": "PorcLogro",
        "agrupar_por": "Curso",
        "titulo": "Rendimiento Promedio por Curso",
        "ylabel": "Logro (%)"
      }
    },
    {
      "tipo": "chart",
      "titulo": "Distribución de Logro por Curso",
      "fn": "boxplot_valor_por_curso",
      "df_input": "estudiantes_prueba",
      "params": {
        "columna_valor": "PorcLogro",
        "agrupar_por": "Curso",
        "titulo_grafico": "Distribución de Logro por Curso",
        "ylabel": "Logro (%)",
        "formato": "percent"
      }
    },
    {
      "tipo": "chart",
      "titulo": "Evolución del Logro Promedio por Curso y Mes",
      "fn": "valor_promedio_agrupado_por",
      "df_input": "estudiantes",
      "params": {
        "columna_valor": "PorcLogro",
        "agrupar_principal_por": "Curso",
        "agrupar_secundario_por": "Mes",
        "titulo_grafico": "Evolución del Logro Promedio por Curso y Mes",
        "titulo_leyenda": "Mes",
        "y_lims": [0, 1],
        "formato": "percent"
      }
    },
    {
      "tipo": "chart",
      "titulo": "Cantidad de Alumnos por Nivel de Logro y Curso",
      "fn": "alumnos_por_nivel_cualitativo",
      "df_input": "estudiantes_prueba",
      "params": {
        "columna_nivel": "Nivel_Logro",
        "agrupar_por": "Curso",
        "lista_niveles": ["Adecuado", "Elemental", "Insuficiente"],
        "titulo_grafico": "Cantidad de Alumnos por Nivel de Logro y Curso",
        "titulo_leyenda": "Nivel de Logro",
        "ylabel": "Cantidad de Alumnos"
      }
    },
    {
      "tipo": "chart",
      "titulo": "Logro Promedio por Habilidad",
      "fn": "valor_promedio_agrupado_por",
      "df_input": "habilidad",
      "params": {
        "columna_valor": "LogroHabilidad",
        "agrupar_principal_por": "Curso",
        "agrupar_secundario_por": "Habilidad",
        "titulo_grafico": "Logro Promedio por Habilidad",
        "titulo_leyenda": "Habilidad",
        "formato": "percent"
      }
    }
  ],
  "secciones_dinamicas": {
    "_comment": "Iteración por curso: 1 tabla detalle de alumnos por curso. No incluye 'Logro por Pregunta' porque no hay datos por pregunta.",
    "iterar_por": "Curso",
    "df_iterar": "estudiantes_prueba",
    "secciones": [
      {
        "tipo": "table",
        "titulo": "Logro por Alumno - {curso}",
        "fn": "tabla_logro_por_alumno",
        "df_input": "estudiantes_prueba",
        "params": {
          "parametros": {"Curso": "{curso}"},
          "sort_by": "PorcLogro",
          "formatos": {
            "PorcLogro": "percent",
            "Logro_Promedio_Estudiante": "percent",
            "Avance": "percent",
            "Mejora_vs_Inicio": "percent"
          },
          "columnas": ["Nombre", "PorcLogro", "Nivel_Logro", "Logro_Promedio_Estudiante", "Avance", "Mejora_vs_Inicio"],
          "columnas_renombrar": {
            "Nombre": "Estudiante",
            "PorcLogro": "Logro",
            "Nivel_Logro": "Nivel",
            "Logro_Promedio_Estudiante": "Promedio Año",
            "Avance": "Avance",
            "Mejora_vs_Inicio": "Mejora"
          }
        }
      }
    ]
  }
}
