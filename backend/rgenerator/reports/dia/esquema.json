{
  "_comment": "Esquema declarativo del informe DIA. Reusa charts.py / tables.py de SIMCE — solo cambian los parámetros (lista_niveles ['Avanzado','Intermedio','Inicial'], columna 'Logro' en lugar de 'Rend', sin SIMCE puntaje).",
  "derived_fields": [
    {
      "_comment": "Por ahora solo Logro_Promedio_Estudiante (mean por estudiante dentro del hito mostrado). Para activar Avance y Mejora_vs_Inicio, los pipelines DIA (data/pipelines/dia/) ya guardan 'Nombre_Norm' en metric_data via el kind normalize_name (apellidos+nombre ordenados alfabéticamente, resuelve el bug DIAG 'Nombre Apellido' vs INTER 'Apellido Nombre'). Cuando metric_data tenga la columna 'Nombre_Norm' poblada para todos los hitos, descomentar las dos configs de abajo y reemplazar 'Nombre' por 'Nombre_Norm' en entity_field.",
      "df_input": "estudiantes",
      "configs": [
        {
          "kind": "agg",
          "name": "Logro_Promedio_Estudiante",
          "value_field": "Logro",
          "entity_field": ["Curso", "Nombre"],
          "agg": "mean",
          "min_points": 1
        }
      ]
    }
  ],
  "_derived_fields_pendientes_normalize": [
    {
      "kind": "slope",
      "name": "Avance",
      "value_field": "Logro",
      "entity_field": ["Curso", "Nombre_Norm"],
      "time_field": "Hito",
      "time_type": "ordinal",
      "time_ordinal_levels": ["DIAGNOSTICO", "INTERMEDIO", "FINAL"],
      "min_points": 2
    },
    {
      "kind": "delta",
      "name": "Mejora_vs_Inicio",
      "value_field": "Logro",
      "entity_field": ["Curso", "Nombre_Norm"],
      "time_field": "Hito",
      "time_type": "ordinal",
      "time_ordinal_levels": ["DIAGNOSTICO", "INTERMEDIO", "FINAL"],
      "min_points": 2
    }
  ],
  "title": "Informe DIA",
  "subtitle": "Resumen del hito seleccionado",
  "filters_label": "",
  "branding": {
    "left_image": "logo_php.png",
    "right_image": "pullinque_php.png",
    "center_header": [
      "Informe DIA Diagnóstico",
      "Asignatura Nivel Medio",
      "Mes Año"
    ],
    "left_footer": "Miguel Godoy Díaz",
    "show_page_number": true
  },
  "secciones_fijas": [
    {
      "tipo": "table",
      "titulo": "Cuadro Resumen Logro por Curso",
      "fn": "resumen_estadistico_basico",
      "df_input": "estudiantes",
      "params": {
        "columna": "Logro",
        "formato": "percent",
        "agrupar_por": "Curso"
      }
    },
    {
      "tipo": "chart",
      "titulo": "Logro Promedio por Nivel",
      "fn": "grafico_barras_promedio_por",
      "df_input": "estudiantes",
      "params": {
        "columna_valor": "Logro",
        "agrupar_por": "Nivel",
        "titulo": "Logro Promedio por Nivel",
        "ylabel": "Logro (%)"
      }
    },
    {
      "tipo": "chart",
      "titulo": "Logro Promedio por Curso",
      "fn": "grafico_barras_promedio_por",
      "df_input": "estudiantes",
      "params": {
        "columna_valor": "Logro",
        "agrupar_por": "Curso",
        "titulo": "Logro Promedio por Curso",
        "ylabel": "Logro (%)"
      }
    },
    {
      "tipo": "chart",
      "titulo": "Distribución de Rendimiento por Curso",
      "fn": "boxplot_valor_por_curso",
      "df_input": "estudiantes",
      "params": {
        "columna_valor": "Logro",
        "agrupar_por": "Curso",
        "titulo_grafico": "Distribución de Rendimiento por Curso",
        "ylabel": "Rendimiento (%)",
        "ylims": [0, 1],
        "formato": "percent"
      }
    },
    {
      "tipo": "chart",
      "titulo": "Logro Promedio por Eje Temático",
      "fn": "valor_promedio_agrupado_por",
      "df_input": "preguntas",
      "params": {
        "columna_valor": "Logro",
        "agrupar_principal_por": "Curso",
        "agrupar_secundario_por": "Eje Temático",
        "titulo_grafico": "Logro Promedio por Eje Temático",
        "titulo_leyenda": "Eje Temático",
        "formato": "percent",
        "y_lims": [0, 1]
      }
    },
    {
      "tipo": "chart",
      "titulo": "Logro Promedio por Habilidad",
      "fn": "valor_promedio_agrupado_por",
      "df_input": "preguntas",
      "params": {
        "columna_valor": "Logro",
        "agrupar_principal_por": "Curso",
        "agrupar_secundario_por": "Habilidad",
        "titulo_grafico": "Logro Promedio por Habilidad",
        "titulo_leyenda": "Habilidad",
        "formato": "percent",
        "y_lims": [0, 1]
      }
    },
    {
      "tipo": "chart",
      "titulo": "Cantidad de Alumnos por Nivel de Logro",
      "fn": "alumnos_por_nivel_cualitativo",
      "df_input": "estudiantes",
      "params": {
        "columna_nivel": "Nivel Logro",
        "agrupar_por": "Curso",
        "lista_niveles": ["Avanzado", "Intermedio", "Inicial"],
        "titulo_grafico": "Cantidad de Alumnos por Nivel de Logro y Curso",
        "titulo_leyenda": "Nivel de Logro",
        "ylabel": "Cantidad"
      }
    }
  ],
  "secciones_dinamicas": {
    "_comment": "TODO próximo iter: 2 tablas por curso (alumnos + preguntas)",
    "iterar_por": "Curso",
    "df_iterar": "estudiantes",
    "secciones": [
      {
        "tipo": "table",
        "titulo": "Logro por Alumno - {curso}",
        "fn": "tabla_logro_por_alumno",
        "df_input": "estudiantes",
        "params": {
          "parametros": {"Curso": "{curso}"},
          "sort_by": "Logro",
          "formatos": {
            "Logro": "percent",
            "Logro_Promedio_Estudiante": "percent"
          },
          "columnas": ["Numero Lista", "Nombre", "Logro", "Nivel Logro", "Logro_Promedio_Estudiante"],
          "columnas_renombrar": {
            "Numero Lista": "N° Lista",
            "Nombre": "Estudiante",
            "Nivel Logro": "Nivel",
            "Logro_Promedio_Estudiante": "Promedio Hito"
          }
        }
      },
      {
        "tipo": "table",
        "titulo": "Logro por Pregunta - {curso}",
        "fn": "tabla_logro_por_pregunta",
        "df_input": "preguntas",
        "params": {
          "valor_agrupacion": "{curso}",
          "agrupar_por": "Curso",
          "sort_by": "Logro",
          "columnas": ["N° Pregunta", "Eje Temático", "Habilidad", "Logro", "Nivel Logro"]
        }
      }
    ]
  }
}
