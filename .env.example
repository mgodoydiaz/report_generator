# ============================================================
# Variables de entorno — PLANTILLA
# Copiar este archivo a .env y completar con valores reales
# ============================================================

# --- Base de datos PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rgenerator_dev
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DATABASE_URL=postgresql://tu_usuario:tu_password@localhost:5432/rgenerator_dev

# --- Autenticación JWT ---
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CAMBIAR_POR_CLAVE_SECRETA_ALEATORIA
JWT_EXPIRE_HOURS=8

# --- Entorno ---
ENVIRONMENT=development
DEBUG=true

# --- CORS (frontend dev) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
