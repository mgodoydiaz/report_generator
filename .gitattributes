# Forzar LF para todos los archivos de texto en todos los sistemas operativos.
# Esto previene problemas de CRLF entre Windows, WSL2 y Linux/Mac.

* text=auto eol=lf

# Archivos explícitamente de texto — siempre LF
*.py        text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.toml      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.env       text eol=lf
*.example   text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.sql       text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf

# Windows batch — mantener CRLF solo en estos
*.bat       text eol=crlf

# Binarios — sin conversión
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.xlsx      binary
*.xls       binary
*.docx      binary
*.doc       binary
*.zip       binary
*.gz        binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
